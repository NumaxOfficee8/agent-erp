{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "erp-agent",
  "version": "0.1.0",
  "identifier": "com.peter.erp-agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "erp-agent",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://peter.github.io/erp-agent/update.json"
      ],
      "pubkey": "dW5pcXVlX3B1YmxpY19rZXlfZm9yX3BpbmdfdXBkYXRlc19wbGFjZWhvbGRlcg=="
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
