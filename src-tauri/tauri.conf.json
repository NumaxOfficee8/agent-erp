{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "erp-agent",
  "version": "0.1.0",
  "identifier": "com.numaxofficee8.agent-erp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "erp-agent",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://numaxofficee8.github.io/agent-erp/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxMEQ5NzAxQjBGRjkzMTIKUldRU2svK3dBWmNOOFNCM1F2Zk15YzdGbFgxYk9YOCtWbHh0Q0NCcmpIa1NhWGh0UFluajRha2IK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
